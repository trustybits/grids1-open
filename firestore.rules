rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function layoutDoc(layoutId) {
      return get(/databases/$(database)/documents/layouts/$(layoutId));
    }

    function isLayoutOwner(layoutId) {
      return request.auth != null
        && layoutDoc(layoutId).data.userId == request.auth.uid;
    }

    match /users/{userId} {
      // Only allow users to read their own document
      allow read: if request.auth != null && request.auth.uid == userId;

      // Allow user to create/update their own document
      // storageUsed field can only be updated by Cloud Functions (server-side)
      // slug field must match format requirements and is validated by Cloud Function
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && (!('storageUsed' in request.resource.data) || request.resource.data.storageUsed == 0);

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && (!('storageUsed' in request.resource.data)
                        || request.resource.data.storageUsed == resource.data.storageUsed);
    }

    match /slugs/{slug} {
      // Allow public read access for slug lookups
      // Document structure: {
      //   userId: string | null (null when released),
      //   createdAt: timestamp,
      //   history: array of { userId: string, claimedAt: timestamp, releasedAt?: timestamp }
      // }
      allow read: if true;

      // Only Cloud Functions can write to this collection
      allow write: if false;
    }

    match /publicProfiles/{userId} {
      // Publicly readable — contains only non-sensitive fields (profilePhotoUrl)
      allow read: if true;

      // Only the profile owner may write their own public profile
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /layouts/{layoutId} {
      allow read: if true;

      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isLayoutOwner(layoutId);

      match /tiles/{tileId}/messages/{messageId} {
        allow read: if true;

        allow create: if exists(/databases/$(database)/documents/layouts/$(layoutId))
          && request.resource.data.keys().hasOnly(["text", "createdAt", "authorId"])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && request.resource.data.createdAt != null
          && (!("authorId" in request.resource.data) || request.resource.data.authorId is string);

        allow update, delete: if isLayoutOwner(layoutId);
      }

      // Upvotes for roadmap feed tiles.
      match /tiles/{tileId}/upvotes/{docId} {
        allow read: if true;
        allow write: if false;
      }

      // notionTokens subcollection — Cloud Functions only.
      match /notionTokens/{tileId} {
        allow read, write: if false;
      }
    }

    match /userGameData/{userId} {
      function isNewDay() {
        let today = '' + request.time.year() + '-' + request.time.month() + '-' + request.time.day();
        return resource.data.get('lastClickDate', '') != today;
      }

      function clickIncrement() {
        return request.resource.data.totalClicks - resource.data.totalClicks;
      }

      function newDailyTotal() {
        return isNewDay() ? clickIncrement() : resource.data.get('dailyClicks', 0) + clickIncrement();
      }

      function isValidClick() {
        return request.auth != null
          && clickIncrement() > 0 && clickIncrement() <= 10
          && newDailyTotal() <= 100
          && request.resource.data.updatedAt == request.time;
      }

      function isValidPassive() {
        return request.auth != null && request.auth.uid == userId
          && clickIncrement() == (request.resource.data.get('totalPassiveClicks', 0) - resource.data.get('totalPassiveClicks', 0));
      }

      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isValidClick() || isValidPassive();
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── Stripe / firestore-stripe-payments Extension ───────────────────────
    //
    // The Extension writes subscription, payment, and customer data into this
    // collection via the Firebase Admin SDK (bypasses these rules).
    //
    // Clients may:
    //   - Read their own customer/subscription/payment data
    //   - Write checkout_sessions (to trigger a new Stripe Checkout session)
    //
    // Clients may NOT write to subscriptions or payments — those are Extension-only.

    match /customers/{uid} {
      // Only the owner can read their own customer record
      allow read: if request.auth != null && request.auth.uid == uid;

      // checkout_sessions: client writes to trigger a checkout, reads to get the URL
      match /checkout_sessions/{id} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // subscriptions: written by the Extension only — clients read-only
      match /subscriptions/{id} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // payments: written by the Extension only — clients read-only
      match /payments/{id} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // Products and prices are synced from Stripe by the Extension.
    // Public read so the pricing page can display current prices.
    // Writes are Extension-only.
    match /products/{id} {
      allow read: if true;
      allow write: if false;

      match /prices/{priceId} {
        allow read: if true;
        allow write: if false;
      }
    }
  }
}
